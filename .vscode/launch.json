{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": ["test", "foo", "--", "--test-threads=3"], // Cargo command line to run the debug target
